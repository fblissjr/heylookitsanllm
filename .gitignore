# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# C extensions
*.so

# Ignore all content in the modelzoo directory
modelzoo/*
models.yaml
.env

# But DO NOT ignore the .gitkeep file
!modelzoo/.gitkeep

# Ignore all content in the adapters directory (j-space lenses etc.), keep the dir
adapters/*
!adapters/.gitkeep

# work
archive/
artifacts/
coderef/
GEMINI.md
docs/archive
docs/frontend-mocks/
internal/
logs/
update-coderef.sh

# configs
model.toml
models.toml

# Runtime data at repo root (SQLite DBs, cache files). Package data at
# src/heylook_llm/data/ stays tracked; this only catches the /data runtime dir.
# Pattern note: /data/* lets git re-enter the dir so the .gitkeep exception works;
# /data/ without the star short-circuits recursion and the negation never fires.
/data/*
!/data/.gitkeep
# Any data/ dir directly under apps/
apps/*/data/*
!apps/*/data/.gitkeep
# Safety net: SQLite + observability log files should never land in git
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.duckdb
*.duckdb.wal
*.jsonl
# bench data (legacy paths)
results.tsv
data/bench/
# optloop-lib bench data + fork clones
apps/optloop-lib/results.tsv
apps/optloop-lib/data/
apps/optloop-lib/repos/
apps/optloop-lib/uv.lock
.claude

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Anchored to the repo root: these are setuptools build output at the project
# top level. A bare `lib/`/`lib64/` matches ANY nested source dir of that name
# (it silently swallowed apps/heylook-frontend/src/lib and tests/e2e/lib) --
# anchoring keeps the build-artifact intent without eating source trees.
/lib/
/lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
node_modules/
package-lock.json
*.tsbuildinfo

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

